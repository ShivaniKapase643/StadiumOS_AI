# Server
NODE_ENV=development
PORT=5000
CLIENT_URL=http://localhost:5173

# Database (Neon / Supabase / Render Postgres connection string)
DATABASE_URL="postgresql://user:password@host:5432/stadium_os?sslmode=require"

# JWT
JWT_ACCESS_SECRET=change_this_access_secret_in_production
JWT_REFRESH_SECRET=change_this_refresh_secret_in_production
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Password reset
PASSWORD_RESET_EXPIRES_MIN=30

# Ticket QR signing
QR_SIGNING_SECRET=change_this_qr_secret_in_production

# Cloudinary (optional — falls back to local disk storage under /uploads if unset)
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# SMTP (optional — falls back to an auto-created Ethereal test inbox if unset)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_FROM="Smart Stadium OS <no-reply@stadiumos.dev>"

# Live data simulator — keep this at 45s+ on free-tier Postgres hosting
# (e.g. Neon free tier). Lower values exhaust the monthly network-transfer
# allowance surprisingly fast once this runs continuously in production —
# it has happened twice at 6s and once at 20s.
SIMULATOR_INTERVAL_MS=45000
