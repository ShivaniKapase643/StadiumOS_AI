# In local development these are unset and Vite's dev-server proxy
# (see vite.config.ts) forwards /api and /socket.io to http://localhost:5000.
#
# In production (Netlify), set both to your deployed Render backend URL:
VITE_API_URL=https://YOUR-RENDER-BACKEND-URL.onrender.com/api
VITE_SOCKET_URL=https://YOUR-RENDER-BACKEND-URL.onrender.com
